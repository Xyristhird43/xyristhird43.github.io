# LWA Client ID from your SP-API sandbox app client (Developer Central -> app -> LWA credentials)
SPAPI_CLIENT_ID=amzn1.application-oa2-client.REPLACE_ME

# LWA Client Secret for the same app client (keep secret — never commit .env)
SPAPI_CLIENT_SECRET=amzn1.oa2-cs.v1.REPLACE_ME

# Refresh token from self-authorizing the app for your own seller account
SPAPI_REFRESH_TOKEN=Atzr|REPLACE_ME

# SP-API endpoint — sandbox by default; switch to https://sellingpartnerapi-na.amazon.com once production is approved
SPAPI_BASE=https://sandbox.sellingpartnerapi-na.amazon.com
